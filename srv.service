[Unit]
Description=AI Friday Slack Bot + Web Server
After=network.target

[Service]
Type=simple
User=exedev
Group=exedev
WorkingDirectory=/home/exedev/ai-friday
ExecStart=/home/exedev/ai-friday/ai-friday-bot
Restart=always
RestartSec=5
Environment=HOME=/home/exedev
Environment=USER=exedev
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
